@using PersonalWebsite.Entity.DTO.PortfolioDTO
@using PersonalWebsite.Entity.Result
@model UIResponse<IEnumerable<PortfolioDTOResponse>>
<section id="portfolio">

    <div class="row section-intro">
        <div class="col-twelve">

            <h5>Portföy</h5>
            <h1>Çalışmalarıma Göz Atın</h1>


        </div>
    </div> <!-- /section-intro-->

    <div class="row portfolio-content">

        <div class="col-twelve">
            <div id="folio-wrapper" class="block-1-2 block-mob-full stack">
                @foreach (var item in Model.Data)
                {


                    <div class="bgrid folio-item">
                        <div class="item-wrap">
                            <img src="images/@item.Image" alt="Liberty" style="width:100%;">
                            <a href="#@item.Id" class="overlay">
                                <div class="folio-item-table">
                                    <div class="folio-item-cell">
                                        <h3 class="folio-title">@item.Name</h3>

                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                    <!-- Button trigger modal -->
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
                        Launch static backdrop modal
                    </button>


                    <div id="@item.Id" class="popup-modal slider mfp-hide">

                        <div class="media">
                            <img src="images/@item.Image" alt="" width="100%;" />
                        </div>

                        <div class="description-box">
                            <h4>@item.Name</h4>
                            <p>@item.Description</p>
                        </div>

                        <div class="link-box">
                            <a href="@item.Url" target="_blank">Detay</a>
                            <a class="popup-modal-dismiss">Kapat</a>
                        </div>

                    </div> <!-- /modal-01 -->
                    <!-- /folio-item -->
                    <!-- modal popups - begin
                    ============================================================= -->
                    @*                     <div class="mfp-bg mfp-fade mfp-ready" style="max-height:100vh;overflow:hidden;position: absolute;">

                </div> *@

                }
            </div>
            <!-- portfolio-wrapper -->
            <!-- /portfolio-wrapper -->

        </div>  <!-- /twelve -->

    </div> <!-- /portfolio-content -->

</section>
